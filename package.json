{
  "name": "@figma/my-make-file",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "dev:host": "vite --host",
    "dev:emulator": "vite --mode emulator",
    "preview": "vite preview --host",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "pretest:rules": "node scripts/free-emulator-ports.mjs",
    "test:rules": "firebase emulators:exec --only firestore \"vitest run --config vitest.rules.config.ts\"",
    "pretest:integration": "node scripts/free-emulator-ports.mjs",
    "test:integration": "firebase emulators:exec --only firestore \"vitest run --config vitest.integration.config.ts\"",
    "pretest:e2e": "node scripts/free-emulator-ports.mjs",
    "test:e2e": "firebase emulators:exec --only firestore,auth,functions \"playwright test\""
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "1.1.4",
    "@radix-ui/react-dialog": "1.1.6",
    "@radix-ui/react-label": "2.1.2",
    "@radix-ui/react-progress": "1.1.2",
    "@radix-ui/react-radio-group": "1.2.3",
    "@radix-ui/react-select": "2.1.6",
    "@radix-ui/react-slot": "1.1.2",
    "@radix-ui/react-switch": "1.1.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "firebase": "^12.13.0",
    "lucide-react": "0.487.0",
    "motion": "12.23.24",
    "next-themes": "0.4.6",
    "react-day-picker": "8.10.1",
    "react-easy-crop": "^6.2.2",
    "react-router": "^7.13.0",
    "recharts": "2.15.2",
    "sonner": "2.0.3",
    "tailwind-merge": "3.2.0",
    "tw-animate-css": "1.3.8"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "4.1.12",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "@vitest/ui": "^4.1.10",
    "firebase-tools": "^15.22.4",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "tailwindcss": "4.1.12",
    "typescript": "^6.0.3",
    "vite": "^6.4.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "pnpm": {
    "overrides": {
      "vite": "^6.4.3"
    }
  }
}
