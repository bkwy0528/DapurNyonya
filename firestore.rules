rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'yikbryan0528work@gmail.com';
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Products: anyone can read, only admin can write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders: customers can create + read their own, admin can read/write all.
    // Customers may additionally cancel their own order, but only while it is
    // still Pending Approval and only by setting status to Cancelled.
    match /orders/{orderId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.customerId == request.auth.uid;
      allow update: if isAdmin() || (
        isSignedIn()
        && resource.data.customerId == request.auth.uid
        && resource.data.status == 'Pending Approval'
        && request.resource.data.status == 'Cancelled'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'cancelledAt'])
      );
      allow delete: if isAdmin();
    }

    // Per-date order counters: public read so customers can check remaining
    // capacity at checkout; any signed-in user can write because the counter is
    // maintained client-side alongside order creation/cancellation.
    match /orderCounts/{dateKey} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Settings: anyone can read (business hours / delivery info shown to customers), only admin writes
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Daily limits: anyone can read (to check availability), only admin writes
    match /dailyLimits/{dateKey} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User profiles: users can read/write their own, admin can read all
    match /users/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
      allow read: if isAdmin();
    }

    // Admin profile: admin only
    match /adminProfile/{docId} {
      allow read, write: if isAdmin();
    }

    // Daily order-number counters: any signed-in user can increment (customers assign
    // their own finalized number right after a successful online payment; admins do
    // the same when approving a cash order) — the counter itself holds no sensitive data.
    match /counters/{counterId} {
      allow read, write: if isSignedIn();
    }
  }
}
