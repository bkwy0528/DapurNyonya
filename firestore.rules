rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email in ['yikbryan0528work@gmail.com', 'ksl_joyce@yahoo.com'];
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Products: anyone can read, only admin can write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Ingredient master list: anyone can read, only admin can write
    match /ingredients/{ingredientId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders: customers can read their own, admin can read/write all. Orders
    // are never created directly by a client — the submitOrder Cloud Function
    // (Admin SDK, bypasses these rules) recomputes prices from the real
    // product catalog and checks a server-recorded payment confirmation before
    // writing anything. That closes a prior gap where a client could set its
    // own total or mark itself as paid. Customer self-cancel was removed along
    // with cash: every order is paid before it exists, so customers get no
    // write access at all.
    match /orders/{orderId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow create: if false;
      allow update, delete: if isAdmin();
    }

    // Payment confirmations: written only by the toyyibpayCallback Cloud
    // Function (Admin SDK) when ToyyibPay itself reports a bill's outcome,
    // and read only by submitOrder (also Admin SDK) — never by any client.
    match /paymentConfirmations/{billCode} {
      allow read, write: if false;
    }

    // Per-date order counters: public read so customers can check remaining
    // capacity at checkout. Increments happen only server-side in submitOrder
    // (Admin SDK, bypasses these rules). Customer self-cancel — the one client
    // write this used to allow (decrement-by-1 to release a slot) — is gone,
    // so writes are admin-only now.
    match /orderCounts/{dateKey} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Settings: anyone can read (business hours / delivery info shown to customers), only admin writes
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Daily limits: anyone can read (to check availability), only admin writes
    match /dailyLimits/{dateKey} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Production batches (batch/MOQ ordering): anyone can read (customers see
    // live progress before ordering), only admin writes. currentQuantity/
    // orderCount/batchStatus are actually maintained by the createBatchPreOrder/
    // expireBatchPayments/closeExpiredProductionDates Cloud Functions (Admin
    // SDK, bypasses this rule) — this just lets the admin configure Open/Closed
    // and Min/Max directly, same shape as dailyLimits.
    match /productionBatches/{batchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Batch pre-orders: customers can read only their own, admin can read/write
    // all. Never created directly by a client — createBatchPreOrder (Admin SDK)
    // recomputes the price from the live product catalog and checks batch
    // capacity/MOQ inside a transaction, mirroring how submitOrder is the sole
    // writer of orders/. A batchOrder graduates into a real orders/ doc (via
    // submitBatchOrderPayment) once paid; it is never itself payable-in-place.
    match /batchOrders/{orderId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow create: if false;
      allow update, delete: if isAdmin();
    }

    // User profiles: users can read/write their own, admin can read all
    match /users/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
      allow read: if isAdmin();
    }

    // Admin profile: admin only
    match /adminProfile/{docId} {
      allow read, write: if isAdmin();
    }

    // Daily order-number counters: every order gets its finalized number
    // assigned server-side in submitOrder — no client writes at all anymore,
    // kept admin-only for manual fixes.
    match /counters/{counterId} {
      allow read, write: if isAdmin();
    }
  }
}
