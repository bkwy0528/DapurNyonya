rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email in ['yikbryan0528work@gmail.com', 'ksl_joyce@yahoo.com'];
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Products: anyone can read, only admin can write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders: customers can read their own, admin can read/write all. Orders
    // are never created directly by a client — the submitOrder Cloud Function
    // (Admin SDK, bypasses these rules) recomputes prices from the real
    // product catalog and, for online payments, checks a server-recorded
    // payment confirmation before writing anything. That closes a prior gap
    // where a client could set its own total or mark itself as paid.
    // Customers may still cancel their own order client-side, but only while
    // it is still Pending Approval and only by setting status to Cancelled.
    match /orders/{orderId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow create: if false;
      allow update: if isAdmin() || (
        isSignedIn()
        && resource.data.customerId == request.auth.uid
        && resource.data.status == 'Pending Approval'
        && request.resource.data.status == 'Cancelled'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'cancelledAt'])
      );
      allow delete: if isAdmin();
    }

    // Payment confirmations: written only by the toyyibpayCallback Cloud
    // Function (Admin SDK) when ToyyibPay itself reports a bill's outcome,
    // and read only by submitOrder (also Admin SDK) — never by any client.
    match /paymentConfirmations/{billCode} {
      allow read, write: if false;
    }

    // Per-date order counters: public read so customers can check remaining
    // capacity at checkout. Increments happen only server-side in submitOrder
    // (Admin SDK, bypasses these rules). The only client write allowed is
    // releasing a booked slot — the count decremented by exactly 1 — which is
    // what customer self-cancel does; anything else (arbitrary overwrites that
    // could corrupt capacity checks for other customers) is rejected.
    match /orderCounts/{dateKey} {
      allow read: if true;
      allow write: if isAdmin() || (
        isSignedIn()
        && request.resource.data.keys().hasOnly(['count'])
        && request.resource.data.count is int
        && request.resource.data.count == (resource == null ? -1 : resource.data.count - 1)
      );
    }

    // Settings: anyone can read (business hours / delivery info shown to customers), only admin writes
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Daily limits: anyone can read (to check availability), only admin writes
    match /dailyLimits/{dateKey} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User profiles: users can read/write their own, admin can read all
    match /users/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
      allow read: if isAdmin();
    }

    // Admin profile: admin only
    match /adminProfile/{docId} {
      allow read, write: if isAdmin();
    }

    // Daily order-number counters: online orders get their finalized number
    // assigned server-side in submitOrder now, so the only client writer left
    // is the admin approving a cash order — locked back down to admin.
    match /counters/{counterId} {
      allow read, write: if isAdmin();
    }
  }
}
